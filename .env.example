# ----------------------------------------------------------------------
# 本地/非生产环境配置模板（无真实密钥）
# 使用方式：复制为 .env 后按实际环境修改
#   Linux / macOS:  cp .env.example .env
#   Windows CMD:    copy .env.example .env
#   Windows PS:     Copy-Item .env.example .env
# .env 已被 .gitignore 忽略，请勿将含真实密码的 .env 提交到仓库。
# ----------------------------------------------------------------------

# MySQL（需先在服务器上创建同名数据库，参见 README「本地运行」）
DB_NAME=host_mgr
DB_USER=host_mgr
DB_PASSWORD=change_me
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis（缓存与 Celery 建议使用不同 logical DB）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# 若 Redis 无密码，可留空
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DB_CELERY=1

# 主机 root 密码加密（Fernet 时须为 urlsafe base64 编码的 32-byte key）
# 生成示例（在项目 venv 中执行）:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HOST_PASSWORD_ENCRYPTION_KEY=replace_with_generated_fernet_key

# 可选：加密器类路径，默认 Fernet
# HOST_PASSWORD_ENCRYPTOR=host_mgr.crypto.adapters.FernetEncryptor

# 可选：Celery 时区，默认 Asia/Shanghai
# CELERY_TIMEZONE=Asia/Shanghai
